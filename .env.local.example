# Supabase — projet "content-factory" (récupérés via MCP au Palier 2)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# DeepSeek — clé serveur uniquement, ne jamais exposer côté client
DEEPSEEK_API_KEY=

# Notifs email quotidiennes (US-8.3) — Resend + Vercel Cron, serveur uniquement
# Service-role Supabase : bypasse la RLS pour le cron (pas d'user connecté). NE JAMAIS exposer.
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=
RESEND_FROM=          # ex : Content Factory <digest@ton-domaine.fr> (domaine vérifié Resend)
CRON_SECRET=          # secret partagé : Vercel l'envoie en Authorization: Bearer pour le cron
